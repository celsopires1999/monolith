@baseUrl = http://localhost:5077

### ===========================================
# HOTELS
# ===========================================

### Create Hotel
# @name createHotel
POST {{baseUrl}}/v1/hotels
Content-Type: application/json

{
  "name": "Happy Place",
  "street": "123 Main St",
  "city": "Springfield",
  "state": "IL",
  "country": "USA",
  "zipCode": "62701"
}

### Get Hotel by ID (uses seed hotel — requires seed.sql to be run first)
GET {{baseUrl}}/v1/hotels/22222222-2222-2222-2222-222222222222

### Get Hotel by ID (uses hotel created above via createHotel)
GET {{baseUrl}}/v1/hotels/{{createHotel.response.body.id}}

### Get Hotel - Not Found
GET {{baseUrl}}/v1/hotels/{{$guid}}


### ===========================================
# GUESTS
# ===========================================

### Create Guest
# @name createGuest
POST {{baseUrl}}/v1/guests
Content-Type: application/json

{
  "firstName": "John",
  "lastName": "Doe",
  "email": "john.doe@user.com"
}


### ===========================================
# ROOMS
# ===========================================
# Requires seed.sql to be run first (RoomType with GUID 11111111-1111-1111-1111-111111111111
# and Hotel with GUID 22222222-2222-2222-2222-222222222222)
### ===========================================

### Create Room
# @name createRoom
POST {{baseUrl}}/v1/rooms
Content-Type: application/json

{
  "roomTypeId": "11111111-1111-1111-1111-111111111111",
  "floor": 1,
  "number": "101",
  "hotelId": "22222222-2222-2222-2222-222222222222",
  "isAvailable": true
}

### Get Room by ID
GET {{baseUrl}}/v1/rooms/{{createRoom.response.body.id}}

### Get Room - Not Found
GET {{baseUrl}}/v1/rooms/{{$guid}}


### ===========================================
# RATES
# ===========================================
# Requires seed.sql to be run first (RoomType, Hotel, RoomTypeRate)
### ===========================================

### Get Rates
GET {{baseUrl}}/v1/rates?hotelId=22222222-2222-2222-2222-222222222222&roomTypeId=11111111-1111-1111-1111-111111111111&startDate=2026-06-15&endDate=2026-06-18&roomQuantity=1


### ===========================================
# RESERVATIONS
# ===========================================
# Requires seed.sql to be run first (RoomType, Hotel, RoomTypeInventory)
### ===========================================

### Create Reservation
# @name createReservation
POST {{baseUrl}}/v1/reservations
Content-Type: application/json

{
  "hotelId": "22222222-2222-2222-2222-222222222222",
  "roomTypeId": "11111111-1111-1111-1111-111111111111",
  "startDate": "2026-06-15",
  "endDate": "2026-06-18",
  "guestId": "{{createGuest.response.body.id}}",
  "roomQuantity": 1
}

### Get Reservation by ID
GET {{baseUrl}}/v1/reservations/{{createReservation.response.body.id}}

### List Reservations by Guest
GET {{baseUrl}}/v1/reservations?guestId={{createGuest.response.body.id}}

### Cancel Reservation
DELETE {{baseUrl}}/v1/reservations/{{createReservation.response.body.id}}

### Create Reservation - Invalid Guest (expects 422)
POST {{baseUrl}}/v1/reservations
Content-Type: application/json

{
  "hotelId": "22222222-2222-2222-2222-222222222222",
  "roomTypeId": "11111111-1111-1111-1111-111111111111",
  "startDate": "2026-06-15",
  "endDate": "2026-06-18",
  "guestId": "{{$guid}}",
  "roomQuantity": 1
}


### ===========================================
# PAYMENTS
# ===========================================
# Payment is auto-created when a Reservation is created.
# Set @paymentId at the top of this file.
# Query the DB: SELECT id FROM payments ORDER BY processed_at DESC LIMIT 1;
#
# Status transitions tested (run in order on the SAME payment):
#   Pending -> Processing (paymentProcessing)
#   Processing -> Completed (paymentCompleted)
#   Completed -> Refunded (paymentRefunded)
#
# Alternative path (requires a different payment in Pending state):
#   Pending -> Processing (paymentProcessing)
#   Processing -> Failed (paymentFailed)
#
# Status enum values: 1=Pending, 2=Processing, 3=Completed, 4=Failed, 5=Refunded
### ===========================================

@paymentId = aa984f80-70fe-49dc-b710-61ef5f107c24

### Update Payment Status - Processing (Pending -> Processing)
PATCH {{baseUrl}}/v1/payments/{{paymentId}}
Content-Type: application/json

{
  "status": 2,
  "transactionId": "TXN-001"
}

### Update Payment Status - Completed (Processing -> Completed)
PATCH {{baseUrl}}/v1/payments/{{paymentId}}
Content-Type: application/json

{
  "status": 3,
  "transactionId": "TXN-001"
}

### Update Payment Status - Refunded (Completed -> Refunded)
PATCH {{baseUrl}}/v1/payments/{{paymentId}}
Content-Type: application/json

{
  "status": 5,
  "transactionId": "TXN-REFUND-001"
}

### Update Payment Status - Failed (requires a payment in Processing state)
PATCH {{baseUrl}}/v1/payments/{{paymentId}}
Content-Type: application/json

{
  "status": 4,
  "transactionId": "TXN-FAILED"
}

### Update Payment Status - Error: cannot set back to Pending (expects 422)
PATCH {{baseUrl}}/v1/payments/{{paymentId}}
Content-Type: application/json

{
  "status": 1,
  "transactionId": "TXN-INVALID"
}
